/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"

#include "xparameters.h"
#include <string.h>
#include <stdint.h>
#include <inttypes.h>

#define reg(k) (*(volatile unsigned int* )(XPAR_FIB_SERIES_0_S00_AXI_BASEADDR + 4*k))
#define cmd_len 128

void my_getline(char* cmd, int size_max){
	int i = 0;
	char c;
	for(i = 0; i < size_max - 1; i++){
		c = getchar();
		if(c == '\n' || c == '\r'){
			c = '\0';
			putchar('\r');
			putchar('\n');
			break;
		}
		putchar(c);
		cmd[i] = c;
	}
	cmd[i] = '\0';
}

void print_help(){
	printf("start    : to start the algorithm \n");
	printf("x        : to quit the program \n");
	printf("h        : to print this help menu \n");
}
int main()
{
	int terminate = 0;
	char cmd[cmd_len];
	uint32_t xdata;
	int led_index;

    init_platform();
    print_help();
    do{
    	printf(">> "); fflush(stdout);
    	my_getline(cmd, cmd_len);
//    	fgets(cmd, cmd_len, stdin);
    	if(!strcmp(cmd, "x")){
    		terminate = 1;
    	} else if(!strcmp(cmd, "h")){
    		print_help();
    	}else if(!strcmp(cmd, "start")){
    		printf("starting the algorithm \n");
    		printf("press n to display the next fibunacci series number \n");
    		int stop = 0;
    		do{
    			my_getline(cmd, cmd_len);
    			if(!strcmp(cmd, "stop")){
    				stop = 1;
    			} else if(!strcmp(cmd, "n")){
    				reg(2) = 1;
    				do{
    					xdata = reg(1);
    				}while(!(xdata & 0x1));
    				xdata = reg(0);
    				led_index = (reg(1) >> 1) & (0b1111);
    				reg(0) = led_index;
    			}
    		}while(stop == 0);
    		printf("fibunacci series printing stopped \n");
    	}
    }while(terminate == 0);

    print("Successfully ran test application");
    cleanup_platform();
    return 0;
}
