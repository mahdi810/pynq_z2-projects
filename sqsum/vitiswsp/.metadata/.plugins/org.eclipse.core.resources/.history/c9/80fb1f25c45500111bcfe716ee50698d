/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"

#include "xparameters.h"
#include <stdint.h>
#include <inttypes.h>
#include <string.h>
#define reg(k) (*(volatile unsigned int* )(XPAR_SQSUM_0_S00_AXI_BASEADDR + 4*k))
#define nreg 5
#define cmd_len 128

void print_help(){
	printf("start    : to start the computation algorithm \n");
	printf("h        : to print this help menu \n");
}

void my_getline(char* cmd, int size){
	int i = 0;
	char c;
	for(i = 0; i < size-1; i++){
		c = getchar();
		if(c == '\n' || c == '\r'){
			c = '\0';
			putchar('\r');
			putchar('\n');
			break;
		}
		putchar(c);
		cmd[i] = c;
	}
	cmd[i] = '\0';
}

int main()
{
	int terminate = 0;
	char cmd;
	uint32_t xdata;

    init_platform();

    do{
    	printf(">> "); fflush(stdout);
    	my_getline(cmd, cmd_len);

    	if(!strcmp(cmd, "x")){
    		terminate = 1;
    	} else if(!strcmp(cmd, "h")){
    		print_help();
    	} else if(!strcmp(cmd, "start")){
    		printf("this section is left for testing, to be implemented later \n");
    	} else if(!strcmp(cmd, "test")){
    		//testing the xdata values.
    		xdata = 234;
    		printf("this is the value of xdata %"PRIu32 " vlaue \n", xdata);
    	}
    }while(terminate == 0);

    print("Hello World\n\r");
    print("Successfully ran Hello World application");
    cleanup_platform();
    return 0;
}











