/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"

#include "xparameters.h"
#include <stdint.h>
#include <inttypes.h>
#include <string.h>
#define reg(k) (*(volatile unsigned int* )(XPAR_SQSUM_0_S00_AXI_BASEADDR + 4*k))
#define nreg 5
#define cmd_len 128

void print_help(){
	printf("start    : to start the computation algorithm \n");
	printf("test     : reserved for testing different part of the system \n");
	printf("h        : to print this help menu \n");
}

void my_getline(char* cmd, int size){
	int i = 0;
	char c;
	for(i = 0; i < size-1; i++){
		c = getchar();
		if(c == '\n' || c == '\r'){
			c = '\0';
			putchar('\r');
			putchar('\n');
			break;
		}
		putchar(c);
		cmd[i] = c;
	}
	cmd[i] = '\0';
}

int main()
{
	int terminate = 0;
	char cmd[cmd_len];
	uint32_t xdata;

    init_platform();

    print_help();
    do{
    	printf(">> "); fflush(stdout);
    	my_getline(cmd, cmd_len);

    	if(!strcmp(cmd, "x")){
    		terminate = 1;
    	} else if(!strcmp(cmd, "h")){
    		print_help();
    	} else if(!strcmp(cmd, "start")){
    		//getting the values from the user
    		printf("enter the values for the array[8] \n");
    		int data[8];
    		for(int j = 0; j < 8; j++){
    			printf("please enter the %d th number \n", j+1);
    			my_getline(cmd, cmd_len);
    			sscanf(cmd, "%d", &data[j]);
    		}
    		printf("you have entered the following numbers \n");
    		for(int k = 0; k < 8; k++){
    			printf("data[%d] : %d \n", k, data[k]);
    		}

    		reg(0) = (data[1] << 16) | (data[0]);
			reg(1) = (data[3] << 16) | (data[2]);
			reg(2) = (data[5] << 16) | (data[4]);
			reg(3) = (data[7] << 16) | (data[6]);
    		reg(4) = 1;
    		do{
    			xdata = reg(1);
    		}while(!(xdata & 0x1));



    	} else if(!strcmp(cmd, "test")){
    		//testing the xdata values.
    		xdata = 234;
    		printf("this is the value of xdata %"PRIu32 " vlaue \n", xdata);

    		int start = 0;
    		reg(4) = 1;
    		int res = reg(1);
    		res = (res & 0x2);
    		printf("the value of start is equal to : %d \n", res);
    	}
    }while(terminate == 0);

    print("Hello World\n\r");
    print("Successfully ran Hello World application");
    cleanup_platform();
    return 0;
}











