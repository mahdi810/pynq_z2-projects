/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"

#include "xparameters.h"
#include <stdint.h>
#include "inttypes.h"

#define reg(k) (*(volatile unsigned int* )(XPAR_SQSUM_0_S00_AXI_BASEADDR + 4*k))
#define cmd_len 128

void print_help(){
	printf("start    : to start the euclidian algorithm \n");
	printf("h        : to display help \n");
	printf("x        : to exit the program \n");
}

//this should be used for the bare metal programming
void my_getline(char* cmd, int size_max){
	int i = 0;
	char c;
	for(i = 0; i < size_max - 1; i++){
		c = getchar();
		if(c == '\n' || c == '\r'){
			putchar('\r');
			putchar('\n');
			break;
		}
		putchar(c);
		cmd[i] = c;
	}
	cmd[i] = '\0';
}

int main()
{
	int terminate = 0;
	char cmd[cmd_len];
	int j = 0;
	unsigned long xdata;

    init_platform();
    print_help();
    do{
    	printf(">> "); fflush(stdout);
    	my_getline(cmd, cmd_len);
    	if(!strcmp(cmd, "x")){
    		terminate = 1;
    	} else if(!strcmp(cmd, "start")){
    		int data[8];
    		for(j = 0; j < 8; j++){
    			printf("please enter the %d number \n", j);
    			my_getline(cmd, cmd_len);
    			sscanf(cmd, "%d", &data[j]);
    		}
    		printf("you have entered the following numbers \n");
    		for (j = 0; j < 8; j++){
    			printf("data[%d] : %d \n", j, data[j]);
    		}
    		reg(0) = (data[1] << 16) | (data[0]);
    		reg(1) = (data[3] << 16) | (data[2]);
    		reg(2) = (data[5] << 16) | (data[4]);
    		reg(3) = (data[7] << 16) | (data[6]);

    		printf("data has been written to the registers \n");

    		//to start the computation
    		reg(4) = 1;
    		printf("start signal has been given \n");

    		//wait untill done = 1;
    		do{
    			xdata = reg(1);
    		}while(!(xdata & 0x1));

    		xdata = reg(0);
    		printf("the result of the computation is : %" PRIu32 "\n", xdata);
    	} else if(!strcmp(cmd, "h")){
    		print_help();
    	}

    }while(terminate == 0);
    print("Hello World\n\r");
    print("Successfully ran Hello World application");
    cleanup_platform();
    return 0;
}
