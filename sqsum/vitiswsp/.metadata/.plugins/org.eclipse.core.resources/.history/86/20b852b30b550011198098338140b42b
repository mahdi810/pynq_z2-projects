//this should be used for the bare metal programming
void my_getline(char* cmd, int size_max){
	int i = 0;
	char c;
	for(i = 0; i < size_max - 1; i++){
		c = getchar();
		if(c == '\n' || c == '\r'){
			putchar('\r');
			putchar('\n');
			break;
		}
		putchar(c);
		cmd[i] = c;
	}
	cmd[i] = '\0';
}

