/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"

#include "xparameters.h"
#include <string.h>
#include <sleep.h>
#include "xuartps_hw.h"

#define reg(k) (*(volatile unsigned int* )(XPAR_ZPERIPH_1_0_S00_AXI_BASEADDR + 4*k))

#define cmd_len 128

void print_help(){
	printf("r <reg_num> : to read the reg_num register \n");
	printf("w <reg_num> : to write to the reg_num register \n");
	printf("x           : to exit the program \n");
	printf("count       : to count up / down with leds \n");
	printf("monitor     : to monitor the peripherals of the board (switches and push buttons) \n");
	printf("h           : to show this help \n");
}

int my_getline(char *buf, int maxlen) {
    int i = 0;
    char c;
    while (i < maxlen - 1) {
        c = getchar();
        if (c == '\r' || c == '\n') {
            putchar('\r');
            putchar('\n');
            fflush(stdout);
            break;
        }
        putchar(c);        // echo character back to PuTTY
        fflush(stdout);
        buf[i++] = c;
    }
    buf[i] = '\0';
    return i;
}

void cmd_process(char* command){
	char* command_p;
	command_p = command;
	while(*command_p != '\0'){
		if(*command_p == '\n' || *command_p == '\r'){
			*command_p = '\0';
			break;
		}
		command_p++;
	}
}

int main()
{
	int terminate = 0;
	char cmd[cmd_len];
	char *chp;
	int xdata;

    init_platform();
    printf("Welcome to the first program on PYNQ_Z2 peripheralV0.0.1 \n");
    print_help();
    do{
    	printf(">> "); fflush(stdout);
//    	fgets(cmd, cmd_len, stdin);
    	my_getline(cmd, cmd_len);
    	cmd[cmd_len - 1] = '\0';
    	chp = cmd;
    	while(*chp != '\0'){
    		if(*chp == '\n' || *chp == '\r'){
    			*chp = '\0';
    		}
    		chp++;
    	}

    	if(!strcmp(cmd, "x")){

    		terminate = 1;
    	} else if(!strcmp(cmd, "h")){
    		print_help();
    	} else if (!strncmp(cmd, "r", 1)){
    		int ki;
    		if(sscanf(&cmd[2], "%d", &ki) == 1){
    			xdata = reg(ki);
    			printf("reg%d : %d \n", ki, xdata);
    		}
    		int sw, pushb;
    		pushb = (xdata & 0xf);
    		sw = ((xdata >> 4) & 0b11);
    		printf("the sw position shows : %d \n", sw);
    		printf("the push button position shows : %d \n", pushb);
    		printf("reading the registers done \n");
    	} else if(cmd[0] == 'w' && cmd[1] == ' '){
    		int led_value;
    		if(sscanf(&cmd[2], "%d" ,&led_value) == 1){
    			if(led_value > 15){
    				printf("There are only 4 leds on the board, so you can only enter numbers up to 15 \n");
    			} else {
    				reg(0) = led_value;
    			}
    		}
    	} else if(!strncmp(cmd, "count", 5)){
    		printf("do you want the counting up or down ? \n");
    		printf(" 1 : to count up \n");
    		printf(" 0 : to count down \n");
    		my_getline(cmd, cmd_len);
    		cmd_process(cmd);
    		int count = 0;
    		int choice;
    		sscanf(cmd, "%d", &choice);

    		if(choice == 1){
    			while(count < 16){
    				reg(0) = count;
					usleep(500000);
					count++;
    			}
    		} else {
    			count = 15;
    			while(count >= 0){
    				reg(0) = count;
    				usleep(500000);
    				count--;
    			}
    		}
    	} else if(!strncmp(cmd, "monitor", 7)){
    		printf("Press any key to stop\n");
    		int prev_val = -1;
    		while(1){
    			xdata = reg(0);
				int pb, sw2;
				pb = (xdata & 0xf);
				sw2 = ((xdata >> 4) & 0b11);
				if(xdata != prev_val){
					printf("PushButton: %d,    Switch: %d   \n", pb, sw2);
					prev_val = xdata;
				}
				usleep(120000);
				if(peekchar() != -1){
					getchar();
					printf("Monitoring Stopped \n");
					break;
				}
    		}
    	} else {
    		printf("you didn't enter a proper value \n");
    	}
    }while(terminate == 0);
	printf("Thank you for using Basic Peripheral program \n");
	printf("Have a nice time \n");
    cleanup_platform();
    return 0;
}
















